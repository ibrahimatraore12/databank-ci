# Copier ce fichier vers .env et adapter les valeurs pour l'environnement local
# Copy this file to .env and adjust the values for the local environment

# Mot de passe de la zone d'administration du dashboard (dashboard/pages/99_Administration.py)
ADMIN_PASSWORD=databank-admin

# Répertoire de suivi MLflow (SQLite local par défaut, voir ml/comparison.py)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# URL du serveur MCP appelé par la page Assistant IA (dashboard/components/mcp_client.py)
# En local via docker-compose : http://mcp-server:8080/mcp (déjà positionné dans docker-compose.yml)
MCP_SERVER_URL=http://localhost:8080/mcp
# Clé requise par le serveur MCP si MCP_API_KEY y est défini (voir mcp_server/databank_mcp_server.py)
MCP_API_KEY=
